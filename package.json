{
  "name": "chimera",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "node tools/install-hooks.mjs",
    "typecheck": "tsc --noEmit --pretty false --allowImportingTsExtensions --allowJs --checkJs",
    "test": "vitest run --passWithNoTests --configLoader runner",
    "lint": "biome check . && pnpm lint:sim-core-determinism",
    "lint:sim-core-determinism": "node tools/check-sim-core-determinism-cli.mjs",
    "commitlint": "commitlint",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^22.19.19",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "lefthook": "^2.1.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
